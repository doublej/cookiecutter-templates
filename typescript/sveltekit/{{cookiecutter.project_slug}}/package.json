{
  "name": "{{ cookiecutter.project_slug }}",
  "version": "0.1.0",
  "description": "{{ cookiecutter.description }}",
  "author": "{{ cookiecutter.author }}",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "lint": "biome check . && stylelint '**/*.{css,svelte}'",
    "lint:fix": "biome check --write . && stylelint --fix '**/*.{css,svelte}'"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "postcss-html": "^1.0.0",
    "stylelint": "^16.0.0",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
