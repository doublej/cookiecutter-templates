{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
{% if cookiecutter.project_type == 'library' %}
    "declaration": true,
    "declarationMap": true,
{% endif %}
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
