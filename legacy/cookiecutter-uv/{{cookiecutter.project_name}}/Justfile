set shell := ["zsh", "-euo", "pipefail"]

default:
    @just --list
    @echo ''
    @echo "branch: $(git branch --show-current 2>/dev/null || echo 'n/a')"

[group('setup')]
install:
    uv sync
    uv run pre-commit install

[group('quality')]
lint:
    uv lock --locked
    uv run pre-commit run -a

[group('quality')]
typecheck:
    uv run mypy

{%- if cookiecutter.deptry == 'y' %}

[group('quality')]
deptry:
    uv run deptry {% if cookiecutter.layout == "src" %}src{% else %}.{% endif %}

{%- endif %}

[group('quality')]
test:
{%- if cookiecutter.codecov == "y" %}
    uv run python -m pytest --cov --cov-config=pyproject.toml --cov-report=xml
{%- else %}
    uv run python -m pytest --doctest-modules
{%- endif %}

[group('quality')]
loc-check:
    #!/usr/bin/env zsh
    setopt null_glob
    err=0
    for f in src/**/*.py {{ cookiecutter.project_slug }}/**/*.py tests/**/*.py; do
        lines=$(wc -l < "$f")
        if (( lines > 400 )); then echo "error: $f ($lines lines, max 400)"; err=1
        elif (( lines > 300 )); then echo "warn: $f ($lines lines, target ≤300)"; fi
    done
    exit $err

[group('quality')]
check:
    @echo '→ Checking file lengths...'
    just loc-check
    @echo '→ Running lint...'
    just lint
    @echo '→ Running typecheck...'
    just typecheck
{%- if cookiecutter.deptry == 'y' %}
    @echo '→ Running deptry...'
    just deptry
{%- endif %}
    @echo '→ Running tests...'
    just test

[group('build')]
build: clean
    uvx --from build pyproject-build --installer uv

{%- if cookiecutter.publish_to_pypi == "y" %}

[group('build')]
publish:
    uvx twine upload --repository-url https://upload.pypi.org/legacy/ dist/*

[group('build')]
build-and-publish: build publish
{%- endif %}

{%- if cookiecutter.mkdocs == "y" %}

[group('develop')]
docs-test:
    uv run mkdocs build -s

[group('develop')]
docs:
    uv run mkdocs serve
{%- endif %}

[group('cleanup')]
clean:
    rm -rf dist/
